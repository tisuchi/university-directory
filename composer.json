{
    "name": "tisuchi/university-directory",
    "description": "A lightweight, structured university registry for Laravel applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Thouhedul Islam",
            "email": "tisuchi@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Tisuchi\\UniversityDirectory\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tisuchi\\UniversityDirectory\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Tisuchi\\UniversityDirectory\\UniversityDirectoryServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
